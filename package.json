{
  "name": "@monochange/actions",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub actions for monochange workflows.",
  "homepage": "https://github.com/monochange/actions#readme",
  "bugs": {
    "url": "https://github.com/monochange/actions/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monochange/actions.git"
  },
  "type": "module",
  "scripts": {
    "check": "vp check",
    "fmt": "vp fmt . --write",
    "fmt:check": "vp fmt --check",
    "lint": "vp lint",
    "test": "vp test",
    "build": "vp pack",
    "all": "pnpm check && pnpm test && pnpm build"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.19",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
