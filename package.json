{
  "name": "@monochange/actions",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub actions for monochange workflows.",
  "homepage": "https://github.com/monochange/actions#readme",
  "bugs": {
    "url": "https://github.com/monochange/actions/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monochange/actions.git"
  },
  "type": "module",
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "check": "tsgo -config tsconfig.json",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint --type-aware .",
    "lint:syntax": "oxlint .",
    "test": "vp test",
    "build": "tsdown",
    "all": "pnpm lint && pnpm fmt:check && pnpm check && pnpm test && pnpm build"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@rslint/tsgo": "^0.5.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.19",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
